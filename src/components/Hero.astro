---
import HeroCanvas from './HeroCanvas.tsx';
---

<section class="relative flex min-h-svh flex-col overflow-hidden">
  <HeroCanvas client:idle />
  <!-- 7:3 spacers keep the text block ~45-50% down the viewport on any
       screen height; hard bottom-anchoring left it far too low on tall
       monitors. -->
  <div class="min-h-16 flex-[7]"></div>
  <div class="pointer-events-none relative z-10 mx-auto w-full max-w-7xl px-6 md:px-10">
    <p class="text-sm uppercase tracking-[0.35em] text-muted" data-reveal>
      Ramiro Rivas &mdash; Software Engineer
    </p>
    <h1
      class="char-reveal font-display mt-6 max-w-5xl text-[clamp(2.6rem,8vw,7rem)] font-semibold leading-[0.95] tracking-tight"
    >
      I build products end to end
    </h1>
    <p class="mt-8 max-w-xl text-lg leading-relaxed text-muted" data-reveal data-delay="0.3">
      Inventory systems, dealer quoting portals, and portfolio websites - with AI
      integrated where it actually earns its place. Eight shipped projects, each
      explained down to the architecture.
    </p>
    <div class="mt-12 flex items-center gap-4 text-xs uppercase tracking-[0.25em] text-muted" data-reveal data-delay="0.45">
      <span class="inline-block h-10 w-px animate-pulse bg-accent"></span>
      <span>Scroll to explore the work</span>
    </div>
  </div>
  <div class="min-h-20 flex-[3]"></div>
</section>
