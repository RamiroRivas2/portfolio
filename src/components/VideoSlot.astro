---
interface Props {
  video: string | null;
  title: string;
  accent: string;
}

const { video, title, accent } = Astro.props;
---

<div class="relative overflow-hidden rounded-2xl border border-paper/10 bg-ink-2" data-reveal>
  {
    video ? (
      <video controls preload="metadata" class="aspect-video w-full" src={video}>
        <track kind="captions" />
      </video>
    ) : (
      <div class="relative flex aspect-video w-full flex-col items-center justify-center gap-4">
        <div
          class="absolute inset-0"
          style={`background: radial-gradient(50% 70% at 50% 40%, ${accent}1a 0%, transparent 70%);`}
        />
        <span
          class="relative flex h-16 w-16 items-center justify-center rounded-full border border-paper/20 text-paper/60"
          aria-hidden="true"
        >
          <svg width="18" height="20" viewBox="0 0 18 20" fill="currentColor">
            <path d="M0 0 L18 10 L0 20 Z" />
          </svg>
        </span>
        <p class="relative text-sm text-muted">
          Video walkthrough of {title} coming soon
        </p>
      </div>
    )
  }
</div>
